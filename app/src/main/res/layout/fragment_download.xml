<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <!-- Top Header Row: Title + File Count + Search Icon + Sort Icon -->
    <TextView
        android:id="@+id/tvDownloadTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Edge Storage"
        android:textSize="26sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/primary_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvFileCount"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"/>

    <TextView
        android:id="@+id/tvFileCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 files"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toTopOf="@id/tvDownloadTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvDownloadTitle"
        app:layout_constraintEnd_toStartOf="@id/btnSearch"
        android:layout_marginEnd="12dp"/>

    <!-- Search Icon (top-right) -->
    <ImageButton
        android:id="@+id/btnSearch"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_search"
        android:contentDescription="Search"
        app:layout_constraintTop_toTopOf="@id/tvDownloadTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvDownloadTitle"
        app:layout_constraintEnd_toStartOf="@id/btnSortHeader"
        android:layout_marginEnd="4dp"/>

    <!-- Sort/Filter Icon (top-right) -->
    <ImageButton
        android:id="@+id/btnSortHeader"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_sort"
        android:contentDescription="Sort"
        app:layout_constraintTop_toTopOf="@id/tvDownloadTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvDownloadTitle"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"/>

    <!-- Expandable Search Bar (HIDDEN by default) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:cardElevation="0dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/input_bg_color"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvDownloadTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_secondary"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search files..."
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginStart="8dp"/>

            <ImageButton
                android:id="@+id/btnCloseSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                app:tint="@color/text_secondary"
                android:contentDescription="Close Search"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Toolbar Row: Sort label (left) + Delete button + Grid/List toggle (right) -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/searchCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Sort label -->
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_sort"
            app:tint="@color/text_secondary"/>

        <TextView
            android:id="@+id/tvSortLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="6dp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Delete Selected -->
        <ImageButton
            android:id="@+id/btnDeleteSelected"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/danger_color"
            android:contentDescription="Delete Selected"
            android:visibility="gone"
            android:layout_marginEnd="8dp"/>

        <!-- View Toggle (Grid <-> List) -->
        <ImageButton
            android:id="@+id/btnToggleView"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_grid_view"
            android:contentDescription="Toggle View"/>
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDownloadList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="@color/input_stroke_color"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No processed files yet"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload a file to the Edge Node to see results"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>