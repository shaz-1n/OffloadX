<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_color">

    <!-- ══ HEADER: search bar ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="16dp"
        android:paddingBottom="6dp">

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/searchCard"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:background="@drawable/search_bar_bg">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_secondary"
                android:importantForAccessibility="no"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search files..."
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:maxLines="1"
                android:layout_marginStart="6dp"/>

            <ImageButton
                android:id="@+id/btnCloseSearch"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_close"
                app:tint="@color/text_secondary"
                android:contentDescription="Clear Search"/>
        </LinearLayout>

        <!-- Sort icon button -->
        <ImageButton
            android:id="@+id/btnSortHeader"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_sort"
            app:tint="@color/text_secondary"
            android:contentDescription="Sort"/>

    </LinearLayout>

    <!-- ══ TOOLBAR: sort label (left) + delete selected (right, hidden) ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/tvSortLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Recent"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:clickable="true"
            android:focusable="true"/>

        <!-- File count -->
        <TextView
            android:id="@+id/tvFileCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 files"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp"/>

        <!-- Delete selected (hidden unless in selection mode) -->
        <ImageButton
            android:id="@+id/btnDeleteSelected"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/danger_color"
            android:contentDescription="Delete Selected"
            android:visibility="gone"
            android:layout_marginEnd="4dp"/>

    </LinearLayout>

    <!-- ══ RECYCLERVIEW ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDownloadList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="12dp"/>

    <!-- ══ EMPTY STATE ══ -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_nav_download"
            app:tint="@color/input_stroke_color"
            android:layout_marginBottom="18dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No processed files yet"
            android:textSize="17sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload a file to the Edge Node to see results here"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</LinearLayout>