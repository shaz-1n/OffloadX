<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="40dp">

        <!-- ══ Task Details Card ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/card_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Task Details"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Task Title"
                    app:hintTextColor="@color/text_secondary"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="@color/text_secondary"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/input_stroke_color"
                    app:boxBackgroundColor="@color/bg_color"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTaskTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Description (Optional)"
                    app:hintTextColor="@color/text_secondary"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeColor="@color/input_stroke_color"
                    app:boxBackgroundColor="@color/bg_color">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTaskDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:inputType="textMultiLine"
                        android:lines="2"
                        android:gravity="top|start" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Configuration Card ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/card_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configuration"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Execution Mode"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary_variant"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnModeComposite"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Composite"
                        android:textColor="@color/white_color"
                        app:backgroundTint="@color/primary_color"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/btnModeComplex"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Complex"
                        android:textColor="@color/text_secondary"
                        app:backgroundTint="@color/input_bg_color"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- Routing Strategy -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Routing Strategy"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary_variant"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btnRoutingAuto"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Auto"
                        android:textColor="@color/white_color"
                        app:backgroundTint="@color/primary_color"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/btnRoutingManual"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Manual"
                        android:textColor="@color/text_secondary"
                        app:backgroundTint="@color/input_bg_color"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- Auto mode description -->
                <TextView
                    android:id="@+id/tvAutoRouteInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Decision Engine will automatically choose the best node (Local / Hub / Cloud) based on battery, network, and file size."
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginBottom="4dp"
                    android:visibility="visible"/>

                <!-- Manual sub-options panel -->
                <LinearLayout
                    android:id="@+id/layoutManualOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select target node:"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbLocal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Local"
                            android:textColor="@color/text_primary"
                            app:buttonTint="@color/primary_color"/>

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbCloud"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hub / Cloud"
                            android:textColor="@color/text_primary"
                            app:buttonTint="@color/primary_color"
                            android:layout_marginStart="16dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvManualRouteInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Local: Process entirely on-device."
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:paddingStart="4dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"/>
                </LinearLayout>

                <!-- Edge Node IP Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edge Node IP Address"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary_variant"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g., 192.168.1.5:8000"
                    app:hintTextColor="@color/text_secondary"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxStrokeWidth="0dp"
                    app:boxBackgroundColor="@color/input_bg_color">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHubIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ File Picker ══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSearchFile"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/primary_color"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/bg_color">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/stat_sys_upload"
                    app:tint="@color/primary_color"
                    android:importantForAccessibility="no"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:id="@+id/tvFileStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:text="Select File for Upload"
                    android:gravity="center" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Upload Button (pill shape) ══ -->
        <Button
            android:id="@+id/btnFinalUpload"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⬆  Upload Task"
            android:textColor="@color/white_color"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/primary_color" />
            
        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>