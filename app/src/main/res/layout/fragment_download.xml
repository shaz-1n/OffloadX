<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- ══ HEADER: "Edge Storage" + count + 🔍 + ↕ ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingTop="22dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tvDownloadTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edge Storage"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:textColor="#2BC0A6"/>

        <TextView
            android:id="@+id/tvFileCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 files"
            android:textSize="13sp"
            android:textColor="#666680"
            android:layout_marginEnd="2dp"/>

        <!-- Search icon button -->
        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_search"
            app:tint="#2BC0A6"
            android:contentDescription="Search"/>

        <!-- Sort icon button -->
        <ImageButton
            android:id="@+id/btnSortHeader"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_sort"
            app:tint="#666680"
            android:contentDescription="Sort"/>

    </LinearLayout>

    <!-- ══ SEARCH BAR (GONE by default, animates in on tap) ══ -->
    <LinearLayout
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/search_bar_bg"
        android:visibility="gone">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            app:tint="#666680"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Search files..."
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666680"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:singleLine="true"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btnCloseSearch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="#666680"
            android:contentDescription="Close Search"/>
    </LinearLayout>

    <!-- ══ TOOLBAR: sort label (left) + delete (hidden) + grid/list toggle (right) ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="10dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_sort"
            app:tint="#666680"/>

        <TextView
            android:id="@+id/tvSortLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Recent"
            android:textSize="13sp"
            android:textColor="#666680"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Delete selected (hidden unless in selection mode) -->
        <ImageButton
            android:id="@+id/btnDeleteSelected"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#E53935"
            android:contentDescription="Delete Selected"
            android:visibility="gone"
            android:layout_marginEnd="4dp"/>

        <!-- Grid / List Toggle -->
        <ImageButton
            android:id="@+id/btnToggleView"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_grid_view"
            app:tint="#2BC0A6"
            android:contentDescription="Toggle Grid/List"/>

    </LinearLayout>

    <!-- ══ RECYCLERVIEW ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDownloadList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="12dp"/>

    <!-- ══ EMPTY STATE ══ -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_nav_download"
            app:tint="#333348"
            android:layout_marginBottom="18dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No processed files yet"
            android:textSize="17sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload a file to the Edge Node to see results here"
            android:textSize="13sp"
            android:textColor="#666680"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</LinearLayout>